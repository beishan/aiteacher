# ============================================================
# TutorAssist NAS 生产环境配置
# 请根据实际 NAS 环境修改以下配置
# ============================================================

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tutor_assist
DB_USER=postgres
# ⚠️ 生产环境请务必修改密码！
DB_PASSWORD=your_secure_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 生产环境请务必修改密码！
REDIS_PASSWORD=your_redis_password_here

# ==================== MinIO 配置 ====================
MINIO_USER=minioadmin
# ⚠️ 生产环境请务必修改密码！
MINIO_PASSWORD=your_minio_password_here
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==================== JWT 密钥 ====================
# ⚠️ 生产环境必须修改！建议至少 256 位随机字符串
JWT_SECRET=change-this-to-a-random-secret-at-least-256-bits-long

# ==================== 服务端口 ====================
# 前端访问端口（NAS Web 界面端口）
FRONTEND_PORT=9931
# 后端 API 端口
BACKEND_PORT=8080
# OnlyOffice 端口
ONLYOFFICE_PORT=8081

# ==================== 外部访问地址 ====================
# 如果通过域名或 IP 访问，修改以下配置
# 例如：http://192.168.1.100:8080
ONLYOFFICE_PUBLIC_URL=http://localhost:8081
BACKEND_PUBLIC_URL=http://localhost:8080

# ==================== AI 配置（可选）====================
# AI_DEFAULT_MODEL=claude
# CLAUDE_API_KEY=your-claude-api-key
# OPENAI_API_KEY=your-openai-api-key
